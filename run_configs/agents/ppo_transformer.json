{
  "agent_type": "ppo_transformer",
  "params": {
    "d_model": 192,
    "n_heads": 6,
    "n_layers": 6,
    "head_hidden_dim": 256,
    "dropout": 0.1,

    "gamma": 0.99,
    "gae_lambda": 0.95,
    "clip_eps": 0.2,
    "clip_eps_vf": 0.2,
    "entropy_coef": 0.01,
    "value_coef": 0.5,
    "target_kl": 0.02,
    "normalize_advantages": true,

    "lr": 3e-4,
    "weight_decay": 0.0,
    "max_grad_norm": 1.0,

    "rollout_steps": 2048,
    "n_epochs": 4,
    "minibatch_size": 256,
    "total_updates": 200,
    "warmup_updates": 10,

    "use_action_mask": true,
    "normalize_rewards": true,

    "use_amp": false,
    "device": "auto"
  }
}
