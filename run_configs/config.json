  "sim": {
    "technicians": {
      "travel_time": 10,
      "fatigue_model": "exponential",
      "fatigue_alpha": 0.5
    },
    "repair": {
      "knowledge_enabled": true,
      "fatigue_enabled": true,
      "failure_wise_knowledge_parameters": true
    },
    "disruptions": {
      "dis_dict": {
        "injury": {
          "trigger": "random",
          "rate": 0.0001,
          "duration_mu": 240.0,
          "duration_sig": 60.0,
          "preemptive": true
        },
        "exhaustion": {
          "trigger": "fatigue",
          "fatigue_coefficient": 0.001,
          "poll_interval": 60.0,
          "duration_mu": 120.0,
          "duration_sig": 30.0,
          "preemptive": true
        },
        "vacation": {
          "trigger": "periodic",
          "interval": 8000.0,
          "jitter": 400.0,
          "duration_mu": 480.0,
          "duration_sig": 120.0,
          "preemptive": false
        }
      }
    }
  },
  "gym": {
    "max_episode_steps": 10000,
    "max_sim_time": 10000.0,
    "invalid_action_mode": "penalize",
    "invalid_action_penalty": -1.0,
    "assignment_reward": 1.0,
    "ticket_wait_time_penalty": 0.01,
    "observation_representation": "structured",
    "observation_mode": "ticket_only",
    "include_fatigue_in_observation": true,
    "include_queue_size_in_observation": true,
    "reward": {
      "assignment": {
        "enabled": true,
        "coefficient": 1.0
      },
      "wait_time": {
        "enabled": true,
        "coefficient": 1.0
      },
      "queue_size": {
        "enabled": false,
        "coefficient": 1.0
      },
      "busy_technician": {
        "enabled": true,
        "coefficient": 0.5
      }
    }
  },
  "ticket_factory": {
    "priority_rules": {
      "motor": 10,
      "pump": 9,
      "bearing": 7,
      "spindle": 8,
      "sensor": 5,
      "general_failure": 6
    },
    "add_randomness": false,
    "random_priority_variance": 0
  }
