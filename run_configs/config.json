    "tech_junior_2": { "template": "junior", "name": "junior_tech_2" }
  },
  "machines": {
    "drill_1": { "template": "drill" },
    "drill_2": { "template": "drill" },
    "paint_1": { "template": "paint" }
  },
  "products": {
    "widget": {
      "product_type": "widget",
      "route": ["Drill", "Paint"]
    }
  },
  "sim": {
    "technicians": {
