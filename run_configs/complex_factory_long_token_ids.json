{
  "technicians": {
    "expert_1": { "template": "expert", "name": "expert_1" },
    "generalist_1": { "template": "generalist", "name": "generalist_1" },
    "junior_1": { "template": "junior", "name": "junior_1" },
    "junior_2": { "template": "junior", "name": "junior_2" }
  },
  "machines": {
    "cnc_1": { "template": "cnc_weibull" },
    "cnc_2": { "template": "cnc_weibull" },
    "assembly_1": { "template": "assembly_mixed" }
  },
  "products": {
    "precision_part": {
      "product_type": "precision_part",
      "route": ["CNC", "Assembly"]
    }
  },
  "sim": {
    "technicians": {
      "travel_time": 15,
      "fatigue_model": "exponential",
      "fatigue_alpha": 0.5
    },
    "repair": {
      "knowledge_enabled": true,
      "fatigue_enabled": true
    }
  },
  "gym": {
    "max_episode_steps": 100000,
    "max_sim_time": 1000000.0,
    "observation_representation": "token_ids",
    "observation_mode": "factory_level",
    "include_technician_fatigue_tokens": true,
    "include_technician_knowledge_tokens": true,
    "tokenizer_seq_length": 64,
    "assignment_reward": 1.0,
    "reward": {
      "fleet_knowledge":         { "enabled": true, "coefficient": 1.0 },
      "fatigue_cost":            { "enabled": true, "coefficient": 1.0 },
      "estimated_repair_time":   { "enabled": true, "coefficient": 0.3 },
      "fleet_availability":      { "enabled": true, "coefficient": 1.0 },
      "throughput_delta":        { "enabled": true, "coefficient": 3.0 },
      "repair_backlog_age":      { "enabled": true, "coefficient": 1.0 },
      "technician_utilization":  { "enabled": true, "coefficient": 1.0 },
      "downtime_cost":           { "enabled": true, "coefficient": 1.5 }
    }
  }
}
