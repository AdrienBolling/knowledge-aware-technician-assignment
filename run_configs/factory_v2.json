      "template": "inspection"
    },
    "qc_2": {
      "template": "inspection"
    }
  },
  "products": {
    "widget": {
      "product_type": "widget",
      "route": [
        "Conveyor",
        "CNC",
        "Drill",
        "Welder",
        "Assembly",
        "Paint",
        "Inspection"
      ]
    }
  },
  "sim": {
    "technicians": {
      "travel_time": 15,
      "fatigue_model": "exponential",
      "fatigue_alpha": 0.5
    },
    "repair": {
      "knowledge_enabled": true,
      "fatigue_enabled": true,
      "min_repair_fraction": 0.3,
      "knowledge_sensitivity": 0.1,
      "failure_wise_knowledge_parameters": true
    },
    "disruptions": {
      "dis_dict": {
        "injury": {
          "trigger": "random",
          "rate": 0.0001,
          "duration_mu": 240.0,
          "duration_sig": 60.0,
          "preemptive": true
        },
        "exhaustion": {
          "trigger": "fatigue",
          "fatigue_coefficient": 0.001,
          "poll_interval": 60.0,
          "duration_mu": 120.0,
          "duration_sig": 30.0,
          "preemptive": true
        },
        "vacation": {
          "trigger": "periodic",
          "interval": 8000.0,
          "jitter": 400.0,
          "duration_mu": 480.0,
          "duration_sig": 120.0,
          "preemptive": false
        }
      }
    }
  },
  "gym": {
    "max_episode_steps": 5000,
    "max_sim_time": 50000.0,
    "observation_representation": "token_ids",
    "observation_mode": "factory_level",
    "include_technician_fatigue_tokens": true,
    "include_technician_knowledge_tokens": true,
    "use_mca_encoder": true,
    "warmup_steps": 300,
    "mca_grid_shape": [
      10,
      10
    ],
    "mca_n_components": 2,
    "tokenizer_seq_length": 128,
    "assignment_reward": 0.1,
    "ticket_wait_time_penalty": 0.01,
    "fleet_knowledge_scale": 10.0,
    "include_fatigue_in_observation": true,
    "include_queue_size_in_observation": true,
    "reward": {
      "assignment": {
        "enabled": true,
        "coefficient": 1.0
      },
      "wait_time": {
        "enabled": true,
        "coefficient": 1.0
      },
      "queue_size": {
        "enabled": true,
        "coefficient": 0.5
      },
      "busy_technician": {
        "enabled": true,
        "coefficient": 1.0
      },
      "fleet_knowledge": {
        "enabled": true,
        "coefficient": 1.5
      },
      "fatigue_cost": {
        "enabled": true,
        "coefficient": 1.0
      },
      "estimated_repair_time": {
        "enabled": true,
        "coefficient": 0.5
      },
      "workload_balance": {
        "enabled": false,
        "coefficient": 1.0
      },
      "machine_criticality": {
        "enabled": false,
        "coefficient": 1.0
      },
      "fleet_availability": {
        "enabled": true,
        "coefficient": 1.0
      },
      "throughput_delta": {
        "enabled": true,
        "coefficient": 2.0
      },
      "repair_backlog_age": {
        "enabled": true,
        "coefficient": 0.5
      },
      "technician_utilization": {
        "enabled": true,
        "coefficient": 0.5
      },
      "downtime_cost": {
        "enabled": true,
        "coefficient": 1.5
      },
      "selection_diversity": {
        "enabled": true,
        "coefficient": 1.0
      }
    }
  },
  "ticket_factory": {
    "priority_rules": {
      "motor": 10,
      "spindle": 9,
      "pump": 8,
      "bearing": 6,
      "torch": 7,
      "drive": 9,
      "electronics": 8,
      "sensor": 5,
      "mechanical": 4,
      "end_effector": 5,
      "general_failure": 5
    },
    "add_randomness": false,
    "random_priority_variance": 0
  }
}
