{
  "technicians": {
    "placeholder_0": { "template": "expert",     "name": "placeholder_0" },
    "placeholder_1": { "template": "senior",     "name": "placeholder_1" },
    "placeholder_2": { "template": "generalist", "name": "placeholder_2" },
    "placeholder_3": { "template": "junior",     "name": "placeholder_3" }
  },

  "machines": {
    "placeholder_machine": { "template": "cnc_weibull" }
  },

  "products": {
    "placeholder_product": {
      "product_type": "widget",
      "route": ["CNC"]
    }
  },

  "sim": {
    "technicians": {
      "travel_time": 15,
      "fatigue_model": "exponential",
      "fatigue_alpha": 0.5
    },
    "repair": {
      "knowledge_enabled": true,
      "fatigue_enabled": true,
      "min_repair_fraction": 0.3,
      "knowledge_sensitivity": 0.002
    },
    "disruptions": {
      "interrupt_on_disrupt": true,
      "dis_dict": {
        "sick_leave": { "mu": 480.0, "sig": 120.0, "prob": 1.0 }
      }
    }
  },

  "gym": {
    "max_episode_steps": 5000,
    "max_sim_time": 50000.0,

    "observation_representation": "token_ids",
    "observation_mode": "tech_aware",
    "include_technician_fatigue_tokens": true,
    "include_technician_knowledge_tokens": true,

    "use_mca_encoder": false,
    "tokenizer_seq_length": 192,

    "assignment_reward": 0.1,
    "ticket_wait_time_penalty": 0.01,
    "fleet_knowledge_scale": 10.0,
    "expose_action_mask": true,

    "reward": {
      "assignment":             { "enabled": true,  "coefficient": 1.0 },
      "wait_time":              { "enabled": true,  "coefficient": 1.0 },
      "queue_size":             { "enabled": true,  "coefficient": 0.5 },
      "busy_technician":        { "enabled": true,  "coefficient": 1.0 },
      "fleet_knowledge":        { "enabled": true,  "coefficient": 1.5 },
      "fatigue_cost":           { "enabled": true,  "coefficient": 1.0 },
      "estimated_repair_time":  { "enabled": true,  "coefficient": 0.5 },
      "fleet_availability":     { "enabled": true,  "coefficient": 1.0 },
      "throughput_delta":       { "enabled": true,  "coefficient": 2.0 },
      "repair_backlog_age":     { "enabled": true,  "coefficient": 0.5 },
      "technician_utilization": { "enabled": true,  "coefficient": 0.5 },
      "downtime_cost":          { "enabled": true,  "coefficient": 1.5 },
      "selection_diversity":    { "enabled": true,  "coefficient": 1.0 }
    }
  },

  "randomized_scenario": {
    "enabled": true,
    "seed": 1234,
    "n_technicians": 4,
    "technician_templates": ["expert", "senior", "generalist", "junior", "trainee"],
    "n_machines_min": 12,
    "n_machines_max": 22,
    "machine_templates": [
      "cnc_weibull",
      "assembly_mixed",
      "assembly_robot",
      "conveyor",
      "welder",
      "inspection"
    ],
    "route_min_length": 3,
    "route_max_length": 6
  },

  "ticket_factory": {
    "priority_rules": {
      "motor": 10,
      "spindle": 9,
      "pump": 8,
      "bearing": 6,
      "torch": 7,
      "drive": 9,
      "electronics": 8,
      "sensor": 5,
      "mechanical": 4,
      "end_effector": 5,
      "general_failure": 5
    },
    "add_randomness": false,
    "random_priority_variance": 0
  }
}
